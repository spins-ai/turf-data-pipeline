# =============================================================================
# turf-data-pipeline — Variables d'environnement
# =============================================================================
# Copiez ce fichier vers .env et remplissez les valeurs.
#   cp .env.example .env
#
# ATTENTION : Ne commitez JAMAIS le fichier .env (il est dans .gitignore).
# =============================================================================

# ---------------------------------------------------------------------------
# API Keys — Sources de donnees
# ---------------------------------------------------------------------------

# PMU (API officielle)
PMU_API_KEY=
PMU_API_SECRET=

# Betfair Exchange
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_PATH=

# Smarkets Exchange
SMARKETS_API_TOKEN=

# OpenMeteo / Meteo France
OPENMETEO_API_KEY=
METEO_FRANCE_API_KEY=

# Racing Post (si scraping authentifie)
RACING_POST_USERNAME=
RACING_POST_PASSWORD=

# Equidia
EQUIDIA_API_KEY=

# IFCE / SIRE
IFCE_API_KEY=

# Arqana
ARQANA_API_KEY=

# Betfair Historical Data
BETFAIR_HISTORICAL_KEY=

# ---------------------------------------------------------------------------
# API Keys — Scrapers externes
# ---------------------------------------------------------------------------

# ZeTurf
ZETURF_USERNAME=
ZETURF_PASSWORD=

# Geny
GENY_API_KEY=

# Canalturf
CANALTURF_USERNAME=
CANALTURF_PASSWORD=

# Turfomania
TURFOMANIA_API_KEY=

# Unibet
UNIBET_API_KEY=

# Zone Turf
ZONE_TURF_API_KEY=

# Paris Turf
PARIS_TURF_API_KEY=

# Oddschecker
ODDSCHECKER_API_KEY=

# ---------------------------------------------------------------------------
# Chemins
# ---------------------------------------------------------------------------

# Repertoire racine du projet (auto-detecte si vide)
PROJECT_DIR=

# Repertoire de sortie des donnees
OUTPUT_DIR=output

# Repertoire des logs
LOG_DIR=logs

# Chemin Python (laisser vide pour utiliser le python du systeme)
PYTHON_PATH=

# ---------------------------------------------------------------------------
# Execution du pipeline
# ---------------------------------------------------------------------------

# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Nombre max de workers pour les phases paralleles
MAX_WORKERS=4

# Timeout par etape en secondes (defaut: 3600 = 1h)
STEP_TIMEOUT=3600

# Pause entre les appels API en secondes
API_PAUSE=0.3

# Taille des batchs pour les appels API
API_BATCH_SIZE=500

# ---------------------------------------------------------------------------
# Base de donnees (optionnel, pour stockage structure)
# ---------------------------------------------------------------------------

# SQLite (defaut)
DB_PATH=output/turf_data.sqlite

# PostgreSQL (optionnel)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=turf_data
# POSTGRES_USER=
# POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Proxy / Reseau
# ---------------------------------------------------------------------------

# Proxy HTTP (si necessaire pour les scrapers)
# HTTP_PROXY=
# HTTPS_PROXY=

# User-Agent personnalise
# USER_AGENT=Mozilla/5.0 (compatible; turf-data-pipeline/1.0)

# ---------------------------------------------------------------------------
# Feature Engineering
# ---------------------------------------------------------------------------

# Nombre de courses historiques a considerer par cheval
HISTORY_LOOKBACK=20

# Fenetre glissante pour les features temporelles (jours)
TEMPORAL_WINDOW_DAYS=365

# Seuil minimum de courses pour calculer des stats
MIN_COURSES_THRESHOLD=3
